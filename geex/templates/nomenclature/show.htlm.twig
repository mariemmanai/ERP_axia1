{% extends 'base.html.twig' %}

{% block title %}Détails de la Nomenclature{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1>Détails de la Nomenclature</h1>

    <div class="card">
        <div class="card-header">
            <h2>Produit Fini: {{ numenclat.produit.reference }}</h2>
        </div>
        <div class="card-body">
            <h3>Matières Premières:</h3>
            <ul class="list-group">
                {% for matiere in numenclat.matieres %}
                <li class="list-group-item">
                    {{ matiere.reference }} - Consommation: {{ numenclat.consommation }} {{ matiere.unite }}
                </li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_nomenclature_edit', {'id': numenclat.id}) }}" class="btn btn-warning">Modifier</a>
        <a href="{{ path('app_nomenclature_index') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
</div>
{% endblock %}