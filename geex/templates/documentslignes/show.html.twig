{% extends 'base.html.twig' %}

{% block title %}Détails de la ligne de document{% endblock %}

{% block body %}
    <h1>Détails de la ligne de document</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>ID</th>
                <td>{{ documentsligne.id }}</td>
            </tr>
            <tr>
                <th>Document ID</th>
                <td>{{ documentsligne.id_document }}</td>
            </tr>
            <tr>
                <th>Article ID</th>
                <td>{{ documentsligne.id_article }}</td>
            </tr>
            <tr>
                <th>Quantité</th>
                <td>{{ documentsligne.qte }}</td>
            </tr>
            <tr>
                <th>Prix unitaire HT</th>
                <td>{{ documentsligne.prixUnitaireHt|number_format(2, ',', ' ') }}</td>
            </tr>
            <tr>
                <th>Prix total HT</th>
                <td>{{ documentsligne.prix_total_ht|number_format(2, ',', ' ') }}</td>
            </tr>
            <tr>
                <th>Remise</th>
                <td>{{ documentsligne.remise|number_format(2, ',', ' ') }}%</td>
            </tr>
        </tbody>
    </table>

    <div class="d-flex gap-2">
        <a href="{{ path('app_documentslignes_index', {'documentId': documentsligne.id_document}) }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour à la liste
        </a>

        <a href="{{ path('app_documentslignes_edit', {'id': documentsligne.id}) }}" class="btn btn-warning">
            <i class="fas fa-edit"></i> Modifier
        </a>

        {{ include('documentslignes/_delete_form.html.twig') }}
    </div>
{% endblock %}