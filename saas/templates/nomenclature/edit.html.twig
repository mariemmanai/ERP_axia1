{{ include('partials/main.html.twig') }}

<head>
	{{ include('partials/title-meta.html.twig', {title: 'Modifier nomenclature'}) }}
	<link href="{{ asset('assets/libs/sweetalert2/sweetalert2.min.css') }}" rel="stylesheet" type="text/css"/>
	<link href="{{ asset('assets/css/bootstrap.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/css/icons.min.css') }}" rel="stylesheet">
	<link href="{{ asset('assets/css/app.min.css') }}" rel="stylesheet">
	<style>
		.composition-row td {
			vertical-align: middle !important;
		}
	</style>
</head>

<body>
	<div id="layout-wrapper">
		{{ include('partials/menu.html.twig') }}

		<div class="main-content">
			<div class="page-content">
				<div class="container-fluid">
					{{ include('partials/page-title.html.twig', {
                        pagetitle: 'Nomenclatures',
                        title: 'Modifier la composition'
                    }) }}

					<div class="row justify-content-center">
						<div class="col-xxl-8">
							<div class="card">
								{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}
								<div class="card-body p-4">
									<div class="row">
										<div class="col-lg-6">
											<div class="mb-3">
												{{ form_label(form.produit, 'Produit fini', {'label_attr': {'class': 'form-label'}}) }}
												<div class="form-control bg-light border-0">
													{{ nomenclature.produit.reference }}
												</div>
												{{ form_widget(form.produit, {'attr': {'class': 'd-none'}}) }}
											</div>
										</div>
										<div class="col-lg-6">
											<div class="mb-3">
												<label class="form-label">Dernière modification</label>
												<div class="form-control bg-light border-0">
													{{ 'now'|date('d/m/Y H:i') }}
													par
													{{ app.user.username }}
												</div>
											</div>
										</div>
									</div>

									<div class="border-top border-top-dashed my-4"></div>

									<h5 class="mb-3">Composition du produit</h5>

									<div class="table-responsive">
										<table class="table table-borderless table-nowrap mb-0">
											<thead class="table-light">
												<tr>
													<th>Matière première</th>
													<th>Consommation</th>
													<th>Unité</th>
													<th class="text-end">Actions</th>
												</tr>
											</thead>
											<tbody id="composition-lignes" data-prototype="{{ form_widget(form.matieres.vars.prototype)|e('html_attr') }}" data-index="{{ form.matieres|length }}">
												{% for matiere in form.matieres %}
													<tr class="composition-row">
														<td>{{ form_widget(matiere.matiere, {'attr': {'class': 'form-select'}}) }}</td>
														<td>{{ form_widget(matiere.consommation, {'attr': {'class': 'form-control'}}) }}</td>
														<td>
															<input type="text" class="form-control bg-light border-0" value="{{ matiere.vars.data.matiere.unite }}" readonly>
														</td>
														<td class="text-end">
															<button type="button" class="btn btn-sm btn-danger remove-ligne">
																<i class="ri-delete-bin-line"></i>
															</button>
														</td>
													</tr>
												{% endfor %}
											</tbody>
											<tfoot>
												<tr>
													<td colspan="4" class="text-end">
														<button type="button" id="add-ligne" class="btn btn-soft-secondary fw-medium">
															<i class="ri-add-fill me-1 align-bottom"></i>
															Ajouter une matière
														</button>
													</td>
												</tr>
											</tfoot>
										</table>
									</div>
								</div>

								<div class="card-body p-4 border-top">
									<div class="hstack gap-2 justify-content-end">
										<button type="submit" class="btn btn-success">
											<i class="ri-save-line align-bottom me-1"></i>
											Mettre à jour
										</button>
										<a href="{{ path('nomenclature_index') }}" class="btn btn-light">
											Annuler
										</a>
									</div>
								</div>
								{{ form_end(form) }}
							</div>
						</div>
					</div>
				</div>
			</div>
			{{ include('partials/footer.html.twig') }}
		</div>
	</div>

	{{ include('partials/vendor-scripts.html.twig') }}
	<script src="{{ asset('assets/libs/sweetalert2/sweetalert2.min.js') }}"></script>
	<script>
		document.addEventListener('DOMContentLoaded', function () { // ... (le même script que dans new.html.twig) ...
});
	</script>
</body></html>
